// ============================================================
//  nextflow.config  ·  variant-qc-pipeline
// ============================================================

manifest {
    name            = 'variant-qc-pipeline'
    author          = 'Nadeem Khan'
    homePage        = 'https://github.com/nkhan119/variant-qc-pipeline'
    description     = 'SNV + CNV analysis pipeline with MultiQC and Plotly reports'
    mainScript      = 'main.nf'
    nextflowVersion = '>=23.04'
    version         = '1.0.0'
}

// ── Default parameters ───────────────────────────────────────
params {
    cohorts        = "Cohort_A,Cohort_B"
    results_dir    = "results"
    min_dp         = 20
    min_gq         = 30
    min_af         = 0.05
    min_qual       = 30
    cnv_min_size   = 1000
    cnv_bin_size   = 500
    ref_genome     = ""
    chroms         = "chr1,chr2,chr3,chr4,chr5,chr6,chr7,chr8,chr9,chr10,chr11,chr12,chr13,chr14,chr15,chr16,chr17,chr18,chr19,chr20,chr21,chr22,chrX,chrY"
    // resource caps
    max_memory     = '128.GB'
    max_cpus       = 32
    max_time       = '24.h'
}

// ── Process defaults ─────────────────────────────────────────
process {
    errorStrategy  = { task.exitStatus in [104, 134, 137, 139, 143, 247] ? 'retry' : 'finish' }
    maxRetries     = 2
    maxErrors      = '-1'

    // Resource labelling
    withLabel: process_low {
        cpus   = { check_max( 2 * task.attempt,   'cpus'   ) }
        memory = { check_max( 4.GB * task.attempt, 'memory' ) }
        time   = { check_max( 2.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_medium {
        cpus   = { check_max( 4 * task.attempt,    'cpus'   ) }
        memory = { check_max( 16.GB * task.attempt,'memory' ) }
        time   = { check_max( 6.h  * task.attempt, 'time'   ) }
    }
    withLabel: process_high {
        cpus   = { check_max( 8 * task.attempt,    'cpus'   ) }
        memory = { check_max( 32.GB * task.attempt,'memory' ) }
        time   = { check_max( 12.h * task.attempt, 'time'   ) }
    }
}

// ── Profiles ──────────────────────────────────────────────────
profiles {

    // ── Local execution ───────────────────────────────────────
    local {
        process.executor = 'local'
        conda.enabled    = true
        conda.useMamba   = false
        process.conda    = "${projectDir}/environment.yaml"
        executor {
            cpus   = 8
            memory = '32 GB'
        }
    }

    // ── SLURM (Narval / Compute Canada) ───────────────────────
    slurm {
        process.executor  = 'slurm'
        conda.enabled     = true
        conda.useMamba    = false
        process.conda     = "${projectDir}/environment.yaml"
        process.clusterOptions = "--account=def-fveyrier_cpu"
        process.queue     = "cpu"
        executor {
            name           = 'slurm'
            queueSize      = 200
            pollInterval   = '30 sec'
            submitRateLimit = '10 sec'
        }
    }

    // ── Test profile (2 chroms, minimal resources) ────────────
    test {
        process.executor  = 'local'
        conda.enabled     = true
        process.conda     = "${projectDir}/environment.yaml"
        params {
            cohorts      = "Cohort_A"
            chroms       = "chr1,chr22"
            min_dp       = 10
            min_gq       = 20
            max_memory   = '8.GB'
            max_cpus     = 4
            max_time     = '2.h'
        }
        executor {
            cpus   = 4
            memory = '8 GB'
        }
    }

    // ── Docker (future compatibility) ─────────────────────────
    docker {
        docker.enabled    = true
        docker.userEmulation = true
    }
}

// ── Nextflow execution reports ────────────────────────────────
report {
    enabled   = true
    file      = "${params.results_dir}/reports/execution_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${params.results_dir}/reports/timeline.html"
    overwrite = true
}
trace {
    enabled        = true
    file           = "${params.results_dir}/reports/trace.tsv"
    overwrite      = true
    fields         = 'task_id,hash,native_id,process,tag,status,exit,submit,start,complete,duration,realtime,cpus,peak_rss,peak_vmem,rchar,wchar'
}
dag {
    enabled   = true
    file      = "${params.results_dir}/reports/pipeline_dag.html"
    overwrite = true
}

// ── Helper function: cap resources ───────────────────────────
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            if (obj.compareTo(params.max_memory as nextflow.util.MemoryUnit) == 1)
                return params.max_memory as nextflow.util.MemoryUnit
            else return obj
        } catch (all) { return obj }
    } else if (type == 'time') {
        try {
            if (obj.compareTo(params.max_time as nextflow.util.Duration) == 1)
                return params.max_time as nextflow.util.Duration
            else return obj
        } catch (all) { return obj }
    } else if (type == 'cpus') {
        try { return Math.min( obj, params.max_cpus as int ) }
        catch (all) { return obj }
    }
}
